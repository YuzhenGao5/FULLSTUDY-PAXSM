  questionnairePhysicalSpeedMaximumSampleGapSec: 0.12
  questionnaireSlotSpeedMaximumTransitionGapSec: 0.5
  questionnaireCalibrationMinimumSlotEvents: 20
  questionnaireCalibrationMinimumPhysicalSamples: 30
  questionnaireConfirmHoldSeconds: 0.8
  questionnaireConfirmHapticInterval: 0.08
  questionnaireConfirmHapticMin: 0.04
  questionnaireConfirmHapticMax: 0.62
  blockProfiles:
  - blockId: baseline
    displayName: Baseline
    targetTlxDimension: low workload baseline
    ruleComplexity: 1
    targetCount: 4
    distractorCount: 3
    targetDistance: 1.35
    targetSize: 0.26
    timeLimitSeconds: 0
    successThresholdStrictness: 0
    feedbackDelaySeconds: 0
    controlNoiseDegrees: 0
    trialsPerBlock: 8
    rationale: Simple rule, near targets, no time pressure, stable feedback.
  - blockId: cognitive_heavy
    displayName: Cognitive-heavy
    targetTlxDimension: Mental Demand
    ruleComplexity: 3
    targetCount: 7
    distractorCount: 6
    targetDistance: 1.55
    targetSize: 0.22
    timeLimitSeconds: 0
    successThresholdStrictness: 0
    feedbackDelaySeconds: 0
    controlNoiseDegrees: 0
    trialsPerBlock: 10
    rationale: Rule switching, memory cue, and distractors should increase attention and working-memory demand.
  - blockId: physical_heavy
    displayName: Physical-heavy
    targetTlxDimension: Physical Demand
    ruleComplexity: 1
    targetCount: 5
    distractorCount: 4
    targetDistance: 2.65
    targetSize: 0.18
    timeLimitSeconds: 0
    successThresholdStrictness: 0.65
    feedbackDelaySeconds: 0
    controlNoiseDegrees: 0
    trialsPerBlock: 10
    rationale: Farther and smaller targets should increase reaching/pointing demand.
  - blockId: temporal_heavy
    displayName: Temporal-heavy
    targetTlxDimension: Temporal Demand
    ruleComplexity: 1
    targetCount: 5
    distractorCount: 4
    targetDistance: 1.55
    targetSize: 0.22
    timeLimitSeconds: 2.25
    successThresholdStrictness: 0
    feedbackDelaySeconds: 0
    controlNoiseDegrees: 0
    trialsPerBlock: 10
    rationale: Short selection window should increase perceived time pressure.
  - blockId: combined_high
    displayName: Combined-high
    targetTlxDimension: Effort / overall workload
    ruleComplexity: 3
    targetCount: 7
    distractorCount: 6
    targetDistance: 2.2
    targetSize: 0.16
    timeLimitSeconds: 2.5
    successThresholdStrictness: 0
    feedbackDelaySeconds: 0.35
    controlNoiseDegrees: 1.5
    trialsPerBlock: 10
    rationale: Combined cognitive, physical, temporal, and feedback demands should increase perceived effort.
